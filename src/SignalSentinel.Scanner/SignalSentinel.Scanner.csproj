<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <PackageId>SignalSentinel.Scanner</PackageId>
    <Version>1.1.0</Version>
    <Description>CLI security scanner for MCP (Model Context Protocol) server configurations. Detects prompt injection, tool poisoning, and supply chain vulnerabilities aligned with OWASP Agentic AI Top 10. Supports stdio, HTTP/SSE, and WebSocket transports.</Description>
    <PackageTags>mcp;security;scanner;ai-agents;owasp;agentic-ai;cli;dotnet-tool;websocket</PackageTags>
    
    <!-- Enable as global dotnet tool -->
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>sentinel-scan</ToolCommandName>
    
    <!-- Assembly info -->
    <AssemblyName>SignalSentinel.Scanner</AssemblyName>
    <RootNamespace>SignalSentinel.Scanner</RootNamespace>
    
    <!-- NuGet Package Configuration -->
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <!-- <PackageIcon>icon.png</PackageIcon> -->
    <PackageReleaseNotes>
v1.1.0 - WebSocket Transport Support
- Added WebSocket transport (ws:// and wss:// URLs)
- Auto-detection of transport from URL scheme
- Config file support for websocket transport type

v1.0.0 - Initial Release
- 10 security rules mapped to OWASP Agentic AI Top 10 (ASI01-ASI10)
- Auto-discovery for Claude Desktop, Cursor, VS Code, Windsurf, Zed
- A-F scoring system with OWASP compliance matrix
- JSON, Markdown, and HTML report generation
- CI mode with exit codes for automated pipelines
    </PackageReleaseNotes>
    
    <!-- SourceLink for debugging support -->
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    
    <!-- Security: Generate SBOM for supply chain transparency -->
    <EnableSbomGeneration>true</EnableSbomGeneration>
    
    <!-- Security: Detect unsafe usages -->
    <EnableUnsafeBinaryFormatterSerialization>false</EnableUnsafeBinaryFormatterSerialization>
    
    <!-- Security: Invariant globalization disabled for UK PII pattern matching -->
    <InvariantGlobalization>false</InvariantGlobalization>
    
    <!-- Package validation -->
    <EnablePackageValidation>true</EnablePackageValidation>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\SignalSentinel.Core\SignalSentinel.Core.csproj" />
  </ItemGroup>

  <!-- SourceLink for GitHub -->
  <ItemGroup>
    <PackageReference Include="Microsoft.SourceLink.GitHub" Version="8.0.0">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <!-- Security Analyzers -->
  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.NetAnalyzers" Version="9.0.0">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <!-- Package content -->
  <ItemGroup>
    <Content Include="DefaultRules.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
  
  <!-- NuGet package assets -->
  <ItemGroup>
    <None Include="..\..\README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
  
  <!-- Package icon (add when available) -->
  <!-- <ItemGroup Condition="Exists('..\..\assets\icon.png')">
    <None Include="..\..\assets\icon.png" Pack="true" PackagePath="\" />
  </ItemGroup> -->

</Project>
