<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <PackageId>SignalSentinel.Scanner</PackageId>
    <Version>1.0.0</Version>
    <Description>CLI security scanner for MCP (Model Context Protocol) server configurations. Detects prompt injection, tool poisoning, and supply chain vulnerabilities aligned with OWASP Agentic AI Top 10.</Description>
    <PackageTags>mcp;security;scanner;ai-agents;owasp;agentic-ai;cli</PackageTags>
    
    <!-- Enable as global dotnet tool -->
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>sentinel-scan</ToolCommandName>
    
    <!-- Assembly info -->
    <AssemblyName>SignalSentinel.Scanner</AssemblyName>
    <RootNamespace>SignalSentinel.Scanner</RootNamespace>
    
    <!-- Security: Generate SBOM for supply chain transparency -->
    <EnableSbomGeneration>true</EnableSbomGeneration>
    
    <!-- Security: Detect unsafe usages -->
    <EnableUnsafeBinaryFormatterSerialization>false</EnableUnsafeBinaryFormatterSerialization>
    
    <!-- Security: Enable invariant globalization for reduced attack surface -->
    <InvariantGlobalization>false</InvariantGlobalization>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\SignalSentinel.Core\SignalSentinel.Core.csproj" />
  </ItemGroup>

  <!-- Security Analyzers - Microsoft only for now -->
  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.NetAnalyzers" Version="9.0.0">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <Content Include="DefaultRules.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
